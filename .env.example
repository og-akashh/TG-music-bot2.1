# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy this file to .env and fill in every value.
#
# NEVER commit .env to version control.
# All secrets must come from environment variables — never hardcode them.
# ══════════════════════════════════════════════════════════════════════════════


# ── Telegram API Credentials ──────────────────────────────────────────────────
# Obtain from https://my.telegram.org → API Development Tools
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token from @BotFather
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pyrogram STRING SESSION for the USERBOT account (needed to join voice chats).
# Generate with:  python3 -c "from pyrogram import Client; Client('s', api_id=..., api_hash=...).run()"
# Or use: https://replit.com/@SpEcHlDe/genStr
SESSION_STRING=your_pyrogram_string_session_here


# ── Bot Identity ──────────────────────────────────────────────────────────────
BOT_NAME=MusicBot

# Your Telegram user ID (get from @userinfobot)
OWNER_ID=123456789

# Optional: Channel/group ID to receive startup/error logs (can be 0 to disable)
LOG_CHANNEL=0


# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:      mongodb://localhost:27017
# Atlas:      mongodb+srv://user:pass@cluster.mongodb.net
DB_URI=mongodb://localhost:27017
DB_NAME=musicbot


# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:      redis://localhost:6379/0
# RedisCloud: redis://:password@host:port/0
REDIS_URL=redis://localhost:6379/0


# ── Spotify API (optional — needed for Spotify URL support) ───────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret


# ── Genius Lyrics API (optional) ──────────────────────────────────────────────
# Create a client at https://genius.com/api-clients
GENIUS_API_TOKEN=your_genius_api_token


# ── Audio / Playback ──────────────────────────────────────────────────────────
# yt-dlp format selector — "bestaudio" for highest quality, or e.g. "bestaudio[abr<=128]"
AUDIO_QUALITY=bestaudio

# Maximum number of tracks allowed in a single chat's queue
MAX_QUEUE_SIZE=100

# Maximum tracks when importing a playlist
MAX_PLAYLIST_SIZE=50

# Seconds before an idle stream is considered hung
STREAM_TIMEOUT=300

# Automatically play related songs when the queue ends (true / false)
AUTO_PLAY=true


# ── Cache ─────────────────────────────────────────────────────────────────────
# Local directory for cached audio files and thumbnails
CACHE_DIR=./cache

# Maximum total size of the audio cache in megabytes before eviction runs
MAX_CACHE_SIZE_MB=2048

# Absolute path to ffmpeg binary (leave blank if ffmpeg is already in PATH)
FFMPEG_PATH=ffmpeg


# ── Language ──────────────────────────────────────────────────────────────────
# Default locale code — must match a file in bot/locales/<code>.json
DEFAULT_LANG=en


# ── Web Dashboard (optional) ──────────────────────────────────────────────────
# Set to true to enable the FastAPI control panel
DASHBOARD_ENABLED=false

# Port the dashboard will listen on
DASHBOARD_PORT=8080

# Secret Bearer token to protect dashboard API endpoints
# Generate a secure random string: python3 -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_SECRET=change_me_to_a_long_random_string_in_production
